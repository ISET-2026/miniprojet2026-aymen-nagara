{% extends 'base.html.twig' %}

{% block title %}Accueil — RecipeHub{% endblock %}

{% block body_class %}{% endblock %}

{% block main_class %}container-fluid p-0 flex-grow-1{% endblock %}

{% block hero_content %}
    <section class="slider_section">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-7 col-lg-6">
                    <div class="detail-box">
                        <h1>RecipeHub</h1>
                        <p>
                            Des recettes partagees par la communaute, des filtres rapides et des idees de saison
                            dans une interface inspiree de Feane.
                        </p>
                        <div class="btn-box">
                            <a href="{{ path('app_recette_index') }}" class="btn1">Parcourir les recettes</a>
                            {% if app.user %}
                                <a href="{{ path('app_favoris_index') }}" class="btn1 ms-2">Mes favoris</a>
                            {% else %}
                                <a href="{{ path('app_login') }}" class="btn1 ms-2">Se connecter</a>
                            {% endif %}
                        </div>
                    </div>
                </div>
                <div class="col-md-5 col-lg-6 text-center">
                    <div class="img-box">
                        <img src="{{ asset('feane/images/o1.jpg') }}" alt="Illustration culinaire" class="img-fluid">
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}

{% block body %}
    <section class="offer_section layout_padding-bottom">
        <div class="offer_container">
            <div class="container">
                <div class="heading_container heading_center mb-3">
                    <h2>Statistiques du moment</h2>
                    <p>Un apercu rapide de la communaute RecipeHub.</p>
                </div>
                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="box h-100">
                            <div class="img-box d-flex align-items-center justify-content-center">
                                <span class="fs-1">🍽️</span>
                            </div>
                            <div class="detail-box">
                                <h5>Recettes publiees</h5>
                                <h6><span>{{ stats.publiees }}</span></h6>
                                <a href="{{ path('app_recette_index') }}">Voir le catalogue</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="box h-100">
                            <div class="img-box d-flex align-items-center justify-content-center">
                                <span class="fs-1">🥄</span>
                            </div>
                            <div class="detail-box">
                                <h5>Moyenne ingredients</h5>
                                <h6><span>{{ stats.moy_ingredients }}</span> par recette</h6>
                                <a href="{{ path('app_recette_index') }}">Explorer</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="box h-100">
                            <div class="img-box d-flex align-items-center justify-content-center">
                                <span class="fs-1">📂</span>
                            </div>
                            <div class="detail-box">
                                <h5>Categories actives</h5>
                                <h6><span>{{ stats.par_cat|length }}</span> themes</h6>
                                <a href="{{ path('app_recette_index') }}">Filtrer</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="food_section layout_padding-bottom">
        <div class="container">
            <div class="heading_container heading_center mb-4">
                <h2>Dernieres recettes publiees</h2>
                <p>Des idees fraiches pour cuisiner sans perdre de temps.</p>
            </div>

            <div class="row">
                {% for r in recettes_recentes %}
                    <div class="col-sm-6 col-lg-4">
                        <div class="box">
                            <div class="img-box">
                                {% if r.imageName %}
                                    <img src="{{ asset('uploads/recettes/' ~ r.imageName) }}" alt="{{ r.titre }}">
                                {% else %}
                                    <span class="fs-1">{{ r.categorie.icone|default('🍽️') }}</span>
                                {% endif %}
                            </div>
                            <div class="detail-box">
                                <h5>{{ r.titre }}</h5>
                                <p class="text-white-50 mb-2">{{ r.categorie.nom }} — {{ r.tempsPreparation|cooking_time_format }} prep.</p>
                                <div class="options">
                                    <h6>{{ difficulty_stars(r.difficulte) }}</h6>
                                    <a href="{{ path('app_recette_show', {id: r.id}) }}">
                                        <i class="fa fa-arrow-right" aria-hidden="true"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12">
                        <p class="text-muted text-center">Chargez les fixtures pour voir des cartes ici.</p>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>
{% endblock %}
