{% extends 'base.html.twig' %}

{% block title %}Mes favoris{% endblock %}

{% block body %}
    <h1 class="h2 mb-4">Mes favoris</h1>

    <div class="row row-cols-1 row-cols-md-2 g-4">
        {% for r in pagination %}
            <div class="col">
                <div class="card h-100 shadow-sm">
                    {% if r.imageName %}
                        <img src="{{ asset('uploads/recettes/' ~ r.imageName) }}" class="card-img-top object-fit-cover" style="height:160px" alt="">
                    {% else %}
                        <div class="card-img-top bg-body-secondary d-flex align-items-center justify-content-center" style="height:160px;font-size:2.5rem">
                            {{ r.categorie.icone|default('🍽️') }}
                        </div>
                    {% endif %}
                    <div class="card-body d-flex flex-column">
                        <h2 class="h6">{{ r.titre }}</h2>
                        <p class="small text-muted">{{ r.dateCreation|time_ago }} — {{ difficulty_stars(r.difficulte) }}</p>
                        <div class="mt-auto d-flex gap-2">
                            <a class="btn btn-sm btn-primary" href="{{ path('app_recette_show', {id: r.id}) }}">Voir</a>
                            <form method="post" action="{{ path('app_favoris_retirer', {id: r.id}) }}"
                                  data-confirm="Retirer des favoris ?">
                                <input type="hidden" name="_token" value="{{ csrf_token('favorite_remove' ~ r.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Retirer</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <p class="text-muted">Aucun favori pour le moment.</p>
        {% endfor %}
    </div>

    <div class="mt-4">
        {{ knp_pagination_render(pagination) }}
    </div>
{% endblock %}
