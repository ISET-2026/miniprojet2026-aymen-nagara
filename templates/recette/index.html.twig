{% extends 'base.html.twig' %}

{% block title %}Recettes{% endblock %}

{% block body %}
    <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center mb-4">
        <h1 class="h2 mb-0">Recettes publiees</h1>
        <span class="text-muted small">{{ resultsTotal }} resultat(s)</span>
    </div>

    <div class="card card-body shadow-sm mb-4">
        {{ form_start(filterForm) }}
        <div class="row g-2 align-items-end">
            <div class="col-md-3">{{ form_row(filterForm.titre) }}</div>
            <div class="col-md-3">{{ form_row(filterForm.categorie) }}</div>
            <div class="col-md-2">{{ form_row(filterForm.difficulte) }}</div>
            <div class="col-md-3">{{ form_row(filterForm.tag) }}</div>
            <div class="col-md-1"><button class="btn btn-outline-primary w-100" type="submit">Filtrer</button></div>
        </div>
        {{ form_end(filterForm) }}
    </div>

    <div class="d-flex flex-wrap gap-2 mb-3 small">
        <span class="me-2 align-self-center text-muted">Tri :</span>
        {{ knp_pagination_sortable(pagination, 'Titre', 'r.titre') }}
        {{ knp_pagination_sortable(pagination, 'Date', 'r.dateCreation') }}
        {{ knp_pagination_sortable(pagination, 'Prep. (min)', 'r.tempsPreparation') }}
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
        {% for r in pagination %}
            <div class="col">
                <div class="card h-100 shadow-sm">
                    {% if r.imageName %}
                        <img src="{{ asset('uploads/recettes/' ~ r.imageName) }}" class="card-img-top object-fit-cover" alt="" style="height:180px">
                    {% else %}
                        <div class="card-img-top bg-body-secondary d-flex align-items-center justify-content-center" style="height:180px;font-size:3rem">
                            {{ r.categorie.icone|default('🍽️') }}
                        </div>
                    {% endif %}
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-1">
                            <h2 class="h5 card-title">{{ r.titre }}</h2>
                            <span class="badge bg-secondary text-nowrap">{{ difficulty_stars(r.difficulte) }}</span>
                        </div>
                        <p class="small text-muted mb-2">
                            <span class="me-1">{{ r.categorie.icone|default('') }}</span>
                            {{ r.categorie.nom }} — {{ (r.tempsPreparation + (r.tempsCuisson|default(0))) }} min
                        </p>
                        <p class="small mb-2">{{ r.dateCreation|time_ago }}</p>
                        {% if r.tags|length %}
                            <div class="mb-2">
                                {% for t in r.tags %}
                                    <span class="badge me-1" style="background-color: {{ t.couleur }}; color: #fff">{{ t.nom }}</span>
                                {% endfor %}
                            </div>
                        {% endif %}
                        <div class="mt-auto d-flex gap-2 align-items-center flex-wrap">
                            <a class="btn btn-sm btn-primary" href="{{ path('app_recette_show', {id: r.id}) }}">Voir</a>
                            {% if is_granted('ROLE_CUISINIER') and app.user is not null and (is_granted('ROLE_ADMIN') or r.auteur.id == app.user.id) %}
                                <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_recette_edit', {id: r.id}) }}">Modifier</a>
                                <form class="d-inline" method="post"
                                      action="{{ path('app_recette_delete', {id: r.id}) }}"
                                      data-confirm="Supprimer cette recette ?">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ r.id) }}">
                                    <button class="btn btn-sm btn-outline-danger">Supprimer</button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <p>Aucune recette ne correspond a votre recherche.</p>
        {% endfor %}
    </div>

    <div class="mt-4">
        {{ knp_pagination_render(pagination) }}
    </div>
{% endblock %}
