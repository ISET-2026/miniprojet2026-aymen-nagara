{% extends 'base.html.twig' %}

{% block title %}Tags{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h2">Tags</h1>
        <a class="btn btn-primary" href="{{ path('app_tag_new') }}">Nouveau tag</a>
    </div>

    <div class="row row-cols-1 row-cols-md-2 g-3">
        {% for t in tags %}
            <div class="col">
                <div class="card shadow-sm">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <span class="badge me-2" style="background-color: {{ t.couleur }}">{{ t.nom }}</span>
                            <code class="small">{{ t.couleur }}</code>
                        </div>
                        <form method="post" action="{{ path('app_tag_delete', {id: t.id}) }}" data-confirm="Supprimer ce tag ?">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_tag' ~ t.id) }}">
                            <button class="btn btn-sm btn-outline-danger">Supprimer</button>
                        </form>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}
